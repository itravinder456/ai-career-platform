# Plain HTTP, no domain/TLS for now — :80 matches any Host header, so this works
# immediately over the EC2 instance's AWS public DNS hostname or bare Elastic IP with
# zero DNS setup. Revisit with a real domain + automatic HTTPS later (swap `:80` for a
# real hostname — Caddy then handles the Let's Encrypt cert automatically).
:80 {
	handle /api/* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
