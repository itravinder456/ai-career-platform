# Production env for services/runtime — copy to `.env.prod` on the EC2 box, fill in real
# values, and never commit the filled-in version. Referenced by
# infrastructure/docker/docker-compose.prod.yml's `runtime` service.

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=16384

# ── Postgres (AWS RDS — checkpointer / conversation memory) ───────────────────
# postgresql://<user>:<password>@<rds-endpoint>:5432/<db-name>
DATABASE_URL=

# ── Qdrant Cloud (retrieval — free-tier cluster, not the local Docker container) ──
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ravinder

# ── Embeddings — OpenAI in production (no Ollama running in this topology) ────
# Must match whatever services/ingestion used for the LAST production ingestion run —
# changing this without re-ingesting leaves stale-dimension vectors in Qdrant Cloud.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
# OTLP/HTTP traces -> Grafana Cloud (or any OTLP-compatible backend). Leave both blank
# to disable tracing (falls back to no-op) — see docs/OBSERVABILITY.md.
OTEL_ENDPOINT=
OTEL_HEADERS=
# LangSmith intentionally left off in production for now — see docs/OBSERVABILITY.md.
# Real conversations would be traced to a third-party service if enabled here.

# ── App identity ───────────────────────────────────────────────────────────────
APP_NAME=ravinder-ai-runtime
HOST=0.0.0.0
PORT=8001
