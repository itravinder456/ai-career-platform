# ── LLM Provider: groq | anthropic | ollama ────────────────────────────────────
LLM_PROVIDER=groq

# ── Groq (free tier — get key at console.groq.com) ────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (set LLM_PROVIDER=anthropic to use) ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Model config ───────────────────────────────────────────────────────────────
# Defaults are set in shared/core constants — override here if needed
# ANTHROPIC_MODEL=claude-sonnet-5
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
