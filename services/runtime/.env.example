# ── LLM Provider: groq | anthropic | ollama ────────────────────────────────────
LLM_PROVIDER=groq

# ── Groq (free tier — get key at console.groq.com) ────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (set LLM_PROVIDER=anthropic to use) ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Postgres (checkpointer — conversation memory) ────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# ── Qdrant (retrieval tool — searches what services/ingestion populates) ──────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ravinder

# ── Embeddings for the retrieval tool: EMBEDDING_PROVIDER = openai | ollama ────
# Independent of LLM_PROVIDER above (that's the chat model) — must match whatever
# services/ingestion used to populate the collection, or retrieval returns noise.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-...

# ── Ollama alternative (local, no API key) ─────────────────────────────────────
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text

# ── Model config ───────────────────────────────────────────────────────────────
# Defaults are set in shared/core constants — override here if needed
# ANTHROPIC_MODEL=claude-sonnet-5
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── App identity ───────────────────────────────────────────────────────────────
APP_NAME=ravinder-ai-runtime
