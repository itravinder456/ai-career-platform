# For running ingestion ONCE against the production Qdrant Cloud cluster — not deployed
# as a container, just run locally (or from CloudShell) whenever the knowledge base
# changes: copy to `.env.prod`, fill in real values, then run against it directly
# (e.g. `cp .env.prod .env && uv run <ingestion entrypoint>`, or point your runner at
# `.env.prod` explicitly) and never commit the filled-in version.
#
# Vector size/embedding model MUST match services/runtime's and services/api's
# .env.prod — all three read/write the same Qdrant Cloud collection.

# ── Qdrant Cloud ────────────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ravinder
QDRANT_VECTOR_SIZE=1536

# ── Embeddings — OpenAI in production (local dev uses Ollama; nothing in the ─────
# production topology runs Ollama, so this MUST be openai, not the local-dev value) ──
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── App identity ───────────────────────────────────────────────────────────────
APP_NAME=ravinder-ai-ingestion
