# Production env for services/api — copy to `.env.prod` on the EC2 box, fill in real
# values, and never commit the filled-in version. Referenced by
# infrastructure/docker/docker-compose.prod.yml's `api` service.
# REDIS_URL and RUNTIME_URL are set directly in docker-compose.prod.yml (point at the
# in-compose redis/runtime services) — no need to set them here.

# ── Postgres (AWS RDS — same instance/database as services/runtime) ───────────
DATABASE_URL=

# ── Qdrant Cloud ────────────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ravinder
QDRANT_VECTOR_SIZE=1536

# ── Auth (admin-only profile writes: PUT /api/v1/profile) ──────────────────────
# Generate a fresh value — do not reuse the one in services/api/.env (dev-only).
ADMIN_SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Frontend and api are same-origin behind Caddy in production (see Caddyfile), so this
# mainly matters for non-browser/defense-in-depth purposes. Set to the real domain.
CORS_ORIGINS=["https://your-domain.example.com"]

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production

# ── App identity ───────────────────────────────────────────────────────────────
APP_NAME=ravinder-ai-api
HOST=0.0.0.0
PORT=8000
