# ── App ───────────────────────────────────────
APP_NAME=ravinder-ai-api
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/portfolio
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=20
SESSION_TTL_SECONDS=7200

# ── Qdrant ────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ravinder
QDRANT_VECTOR_SIZE=1536

# ── Auth ──────────────────────────────────────
ADMIN_SECRET_KEY=change-me
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Observability ─────────────────────────────
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=ravinder-ai
LANGSMITH_TRACING=false
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=ravinder-ai-api

# ── Internal services ─────────────────────────
RUNTIME_URL=http://localhost:8001

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
