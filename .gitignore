# ── Python ────────────────────────────────────
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.mypy_cache/
**/.ruff_cache/
**/.pytest_cache/
**/*.egg-info/
**/dist/
**/build/

# ── Node ──────────────────────────────────────
**/node_modules/
**/.next/
**/out/
**/.turbo/

# ── Environment / secrets ─────────────────────
**/.env
