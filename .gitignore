!**/.env.example

# ── Data / embeddings ─────────────────────────
data/embeddings/*
!data/embeddings/.gitkeep

# ── IDE / tooling ─────────────────────────────
.vscode/
.idea/
.claude/

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────
*.log
logs/
